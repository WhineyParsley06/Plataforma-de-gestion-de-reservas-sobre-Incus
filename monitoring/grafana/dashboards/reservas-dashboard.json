{
  "title": "Plataforma de Reservas sobre Incus",
  "uid": "reservas-incus",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Estado app-api",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "up{job=\"app-api\"}",
          "legendFormat": "app-api"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "type": "stat",
      "title": "Estado app-core",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "up{job=\"app-core\"}",
          "legendFormat": "app-core"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Peticiones app-api",
      "gridPos": {"x": 0, "y": 5, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(app_api_http_requests_total[1m])",
          "legendFormat": "HTTP requests"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "type": "timeseries",
      "title": "Peticiones app-core",
      "gridPos": {"x": 12, "y": 5, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(app_core_http_requests_total[1m])",
          "legendFormat": "HTTP requests"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    }
  ]
}
